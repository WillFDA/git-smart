#!/bin/sh
# Exit on any error
set -e

# Check if there are any staged files
if [ -z "$(git diff --cached --name-only)" ]; then
  echo "No staged files to format"
  exit 0
fi

# Run formatter on all files (not just staged ones to avoid conflicts)
echo "🔧 Running Ultracite formatter..."
pnpm dlx ultracite fix

# Add all changes back to staging area
git add -u

echo "✨ Files formatted by Ultracite"
exit 0
