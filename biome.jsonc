{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": [
    "ultracite"
  ],
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/.pnpm-store",
      "!**/node_modules",
      "!**/dist"
    ]
  },
  "linter": {
    "rules": {
      "performance": {
        "noImgElement": "off"
      },
      "style": {
        "noMagicNumbers": "off"
      }
    }
  }
}
